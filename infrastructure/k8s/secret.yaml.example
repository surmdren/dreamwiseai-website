apiVersion: v1
kind: Secret
metadata:
  name: dreamwiseai-secrets
  namespace: production
type: Opaque
stringData:
  RESEND_API_KEY: "re_your_key_here"
  CONTACT_EMAIL: "consulting@dreamwiseai.com"
  NEXT_PUBLIC_CALENDLY_URL: "https://calendly.com/your-username/30min"
